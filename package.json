  "scripts": {
    "start": "kill-port 3032 && cross-env PORT=3032 react-scripts start",
    "start:local": "kill-port 3032 && cross-env PORT=3032 react-scripts start",
    "start:prod": "kill-port 3000 && cross-env PORT=3000 env-cmd -f .env.production react-scripts start",
    "start:staging": "kill-port 3000 && cross-env PORT=3000 env-cmd -f .env.staging react-scripts start",
    "build": "react-scripts build",
    "build:staging": "env-cmd -f .env.staging npm run build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "docker:staging": "docker-compose -f docker-compose.staging.yml --env-file .env.staging up -d --build",
    "docker:staging:down": "docker-compose -f docker-compose.staging.yml down",
    "docker:local-staging": "docker-compose -f docker-compose.local-staging.yml --env-file .env.staging up -d --build",
    "docker:local-staging:down": "docker-compose -f docker-compose.local-staging.yml down",
    "docker:local-dev": "docker-compose -f docker-compose.local-dev.yml --env-file .env.staging up",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
